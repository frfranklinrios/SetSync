FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-mail.txt .
RUN pip install --no-cache-dir -r requirements-mail.txt

COPY mail_server/ ./mail_server/

RUN mkdir -p data/mail

EXPOSE 25 587

CMD ["python", "-m", "mail_server.run_smtp"]
