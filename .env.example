# ── Produção (Contabo) ─────────────────────────────────────────────
# Fuso horário do app (jobs, digest WhatsApp, datas na folha). Padrão: Fortaleza.
# SETSYNC_TIMEZONE=America/Fortaleza
FLASK_ENV=production
SECRET_KEY=gere-uma-chave-longa-aleatoria-aqui
# SQLite (legado): sqlite:///data/banda.db
DATABASE_URL=postgresql://setsync:senha-forte@postgres:5432/setsync
POSTGRES_PASSWORD=senha-forte

# Admin global (só .env — ou promoção persistente via coluna is_superadmin no banco)
# Inclua todos os logins master, separados por vírgula
SETSYNC_SUPERADMIN_USERNAMES=seu_usuario
SETSYNC_SUPERADMIN_EMAILS=contato@setsync.com.br

# Webmail integrado — superadmin abre /admin/email/ já logado (mesma sessão Flask).
# SMTP roda no serviço ``mail`` do docker-compose.prod.yml (mail_server/).

# WhatsApp — landing /igrejas (DDI+DDD+número, sem + ou espaços)
# WHATSAPP_NUMBER=5511999999999
# WHATSAPP_MESSAGE=Olá! Tenho interesse no SetSync para nossa igreja.
# Legado (ainda suportado): SETSYNC_WHATSAPP=5511999999999

# WhatsApp — notificações da banda (servidor local Evolution API no docker-compose.prod.yml)
# WHATSAPP_PROVIDER=evolution
# WHATSAPP_NOTIFICATIONS_ENABLED=1
# EVOLUTION_API_URL=http://evolution-api:8080
# EVOLUTION_API_KEY=chave-longa-aleatoria
# EVOLUTION_INSTANCE=setsync
# Parear número: https://setsync.com.br/admin/whatsapp/ (superadmin escaneia QR)
# Teste: docker compose -f docker-compose.prod.yml exec web python3 scripts/send_test_whatsapp.py 859998488790
#
# Alternativa Meta Cloud API:
# WHATSAPP_PROVIDER=meta
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_API_TOKEN=EAAx...
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_TEMPLATE_NAME=setsync_notificacao

# HTTPS no Nginx → deixe 1. Teste só em HTTP: SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SECURE=1
# Dias do cookie de login (padrão 2)
SESSION_LIFETIME_DAYS=2
TRUST_PROXY=1

# LGPD — contato do titular / encarregado (exibido em /privacidade e /meus-dados)
# PRIVACY_CONTACT_EMAIL=contato@setsync.com.br
# PRIVACY_DPO_NAME=Encarregado SetSync

# Gunicorn + SQLite (não aumente workers sem migrar para Postgres)
GUNICORN_WORKERS=1
GUNICORN_THREADS=4

# Pipeline de cifras — VPS: sem download YouTube no servidor
CIFRAS_YOUTUBE_NO_SERVER=1
# CIFRAS_TMP_DIR=data/cifras_tmp

# API local de cifras (projeto irmão api-cifras)
# Docker: http://api-cifras:8000  |  host local: http://127.0.0.1:8000
# API_CIFRAS_URL=http://api-cifras:8000

# Web Push — notificações no Android (PWA) e iOS 16.4+ (app na Tela de Início)
# Gerar chaves: python3 scripts/generate_vapid_keys.py
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contato@setsync.com.br

# Google OAuth — redirect URI: https://SEU_DOMINIO/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps — autocomplete de local na agenda
# Console GCP → Credenciais → chave → Restrição HTTP (referrers):
#   https://setsync.com.br/*
#   https://www.setsync.com.br/*
#   https://setsync.dados.tec.br/*
# APIs habilitadas: Maps JavaScript API, Places API, Maps Embed API + faturamento ativo
# Valide: uv run python scripts/validar_google_maps.py
# GOOGLE_MAPS_API_KEY=

# E-mail / SMTP — recuperação de senha, onboarding e avisos de assinatura.
# Sem MAIL_PASSWORD, o app NÃO envia e-mails (só aviso no log) — o resto funciona.
#
# Servidor SMTP integrado (docker-compose.prod.yml → serviço ``mail``):
#   MAIL_SERVER=mail
#   MAIL_PORT=587
#   MAIL_USE_TLS=0             # submissão local sem STARTTLS
#   MAIL_USERNAME=contato@setsync.com.br
#   MAIL_PASSWORD=mesma senha de ADMIN_PASSWORD no .env do servidor_email
#   Teste: docker compose -f docker-compose.prod.yml exec web python3 scripts/send_test_email.py voce@exemplo.com
#
# Alternativa externa: Zoho / Google Workspace (MAIL_USE_TLS=1, MAIL_SERVER=smtp.zoho.com).
# MAIL_DEFAULT_SENDER aceita e-mail simples ou "Nome <email@dominio>".
# MAIL_SERVER=setsync-mail
# MAIL_PORT=587
# MAIL_USE_TLS=0
# MAIL_USE_SSL=0
# MAIL_USERNAME=contato@setsync.com.br
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=SetSync <contato@setsync.com.br>
# MAIL_SENDER_NAME=SetSync

# URL pública canônica (HTTPS) — obrigatório em produção
SETSYNC_CANONICAL_URL=https://setsync.com.br
SETSYNC_ALLOWED_HOSTS=setsync.com.br,www.setsync.com.br,setsync.dados.tec.br,localhost,127.0.0.1
TRUST_PROXY=1
# Playwright PDF: URL interna do Gunicorn (mesmo container)
SETSYNC_INTERNAL_URL=http://127.0.0.1:5000

# Google Ads — conversão de inscrição (cadastro). Ver docs/google-ads-inscricoes.md
# No assistente do Google Ads → meta "Inscrição" → medir por URL:
#   https://setsync.com.br/auth/cadastro-concluido
# (regra: URL contém /auth/cadastro-concluido)
# GOOGLE_ADS_ENABLED=1
# GOOGLE_ADS_ID=AW-XXXXXXXXX
# GOOGLE_ADS_CONVERSION_SIGNUP=oNeICPvVn8AcEO6ei9ZD
# GOOGLE_ADS_ENHANCED=1
# GOOGLE_ADS_CONVERSION_PRIMEIRA_BANDA=
# GOOGLE_ADS_CONVERSION_PRIMEIRA_CIFRA=
# GOOGLE_ADS_CONVERSION_TRIAL=
# GOOGLE_ADS_CONVERSION_PAGO=
# GOOGLE_ANALYTICS_ID=G-BKG770S75L          # GA4 (padrão G-BKG770S75L se omitido)
# GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX       # alternativa ao bloco AW- acima
# GOOGLE_ADS_CONVERSION_VALUE=1.0
# GOOGLE_ADS_CONVERSION_CURRENCY=BRL
# GOOGLE_ADS_DEBUG=1                      # log no console do navegador

# Produção (VPS): MP_ENVIRONMENT=production + MP_ACCESS_TOKEN=APP_USR-...
# WHATSAPP_NUMBER=5511999999999

# Google AdSense — REMOVIDO do produto (variáveis mantidas só por compatibilidade)
# ADSENSE_ENABLED=0
# MP_WEBHOOK_SECRET=string-longa-aleatoria
# MP_ENVIRONMENT=sandbox
# MP_ACCESS_TOKEN_TEST=              # Access Token de TESTE (não Public Key)
# MP_WEBHOOK_SECRET=setsync-webhook-teste-local
# MP_PLAN_INDIVIDUAL_ID=
# MP_PLAN_PRO_ID=
# MP_PLAN_WORSHIP_ID=
# MERCADOPAGO_TRUST_ENABLED=1   # selo "Pagamento via Mercado Pago" em planos/landings (padrão ligado)
# MP_TEST_BASE_URL=http://127.0.0.1:5000
# Produção (VPS): MP_ENVIRONMENT=production + MP_ACCESS_TOKEN=APP_USR-...
# SETSYNC_WHATSAPP=5511999999999

# ── Desenvolvimento local (comente o bloco acima e use) ───────────
# FLASK_ENV=development
# SECRET_KEY=dev-local-only
# DATABASE_URL=sqlite:///data/banda.db
# ALLOW_HTTP_SESSION=1          # só se precisar FLASK_ENV=production em HTTP local
# SETSYNC_SUPERADMIN_USERNAMES=seu_usuario   # mesmo valor do VPS para ver /admin

# API musical v1 (/api/v1/chords, escalas, SVG)
# MUSIC_API_KEY=chave-opcional-para-clientes-externos
# REDIS_URL=redis://redis:6379/0
# MUSIC_API_CACHE_TTL=3600
