# Configurações da Aplicação
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao
DATABASE_URL=sqlite:///data/banda.db
FLASK_ENV=development

# Pipeline de cifras integrado (cifras_tool/ — roda dentro do SetSync, sem servidor externo)
# CIFRAS_TMP_DIR=data/cifras_tmp
# Em VPS (Contabo): desativa download do YouTube no servidor (recomendado)
CIFRAS_YOUTUBE_NO_SERVER=1
# Só se youtube_no_server=0 e processamento no próprio servidor:
# CIFRAS_YOUTUBE_COOKIES_FILE=/app/data/youtube_cookies.txt

# Google OAuth (obtenha em https://console.developers.google.com)
GOOGLE_CLIENT_ID=seu-google-client-id-aqui
GOOGLE_CLIENT_SECRET=seu-google-client-secret-aqui
